# sera remplacé via github action lors d"un push
GEMINI_API_KEY={gemini.api.key}
#le nom "postgres" provient du nom du service dans le fichier docker-compose.yml
#cad la ligne 2 du fichier (note : car "localhost" est dns de loopback de chaque system/conteneur (127.0.0.1),
#et le nom du service est un alias à son ip sur le reseau)
DB_HOST=postgres